{
  "_description": "CyberSentinel — tunable heuristic parameters for all models and stages",
  "_instructions": "Edit values below and re-run the notebook cells. Keys prefixed with '_' are comments.",


  "general": {
    "_comment": "Shared settings across all models",
    "val_size": 0.2,
    "random_state": 42,
    "calibration_method": "sigmoid",
    "min_attack_recall_for_threshold_search": 0.90
  },


  "randomforest": {
    "stage1": {
      "_comment": "Stage 1 binary classifier (Normal vs Attack)",
      "n_estimators": 300,
      "max_depth": 15,
      "min_samples_split": 8,
      "min_samples_leaf": 4,
      "class_weight": "balanced_subsample"
    },
    "stage2": {
      "_comment": "Stage 2 attack-category classifier (DoS, Probe, R2L, U2R)",
      "n_estimators": 300,
      "max_depth": 15,
      "min_samples_split": 8,
      "min_samples_leaf": 4,
      "class_weight": "balanced_subsample"
    }
  },


  "svm": {
    "stage1": {
      "_comment": "Stage 1 binary classifier (Normal vs Attack)",
      "C": 1.0,
      "class_weight": "balanced",
      "dual": false,
      "max_iter": 10000
    },
    "stage2": {
      "_comment": "Stage 2 attack-category classifier (DoS, Probe, R2L, U2R)",
      "C": 1.0,
      "class_weight": "balanced",
      "dual": false,
      "max_iter": 10000
    }
  },


  "xgboost": {
    "stage1": {
      "_comment": "Stage 1 binary classifier (Normal vs Attack)",
      "n_estimators": 400,
      "max_depth": 5,
      "learning_rate": 0.05,
      "subsample": 0.8,
      "colsample_bytree": 0.8,
      "min_child_weight": 5,
      "gamma": 0.3,
      "reg_alpha": 1.0,
      "reg_lambda": 2.0,
      "scale_pos_weight": "auto"
    },
    "stage2": {
      "_comment": "Stage 2 attack-category classifier (DoS, Probe, R2L, U2R)",
      "n_estimators": 400,
      "max_depth": 5,
      "learning_rate": 0.05,
      "subsample": 0.8,
      "colsample_bytree": 0.8,
      "min_child_weight": 3,
      "gamma": 0.2,
      "reg_alpha": 0.5,
      "reg_lambda": 1.5
    }
  },


  "cascade_thresholds": {
    "_comment": "Threshold grid ranges for the cascade decision logic",

    "stage1_low": {
      "_comment": "Below this p(attack), sample is classified as Normal immediately",
      "start": 0.20,
      "stop": 0.76,
      "step": 0.05
    },
    "stage1_strong": {
      "_comment": "Above this p(attack), sample goes straight to Stage 2 attack classification",
      "start": 0.75,
      "stop": 0.96,
      "step": 0.05
    },
    "stage2_conf": {
      "_comment": "Minimum top-1 confidence from Stage 2 to accept an attack prediction",
      "start": 0.30,
      "stop": 0.91,
      "step": 0.05
    },
    "stage2_margin": {
      "_comment": "Minimum gap between top-1 and top-2 category confidence to accept attack",
      "start": 0.05,
      "stop": 0.46,
      "step": 0.05
    }
  },


  "drop_columns": [
    "difficulty",
    "num_outbound_cmds",
    "is_host_login",
    "su_attempted",
    "urgent",
    "land",
    "num_access_files",
    "num_shells",
    "root_shell",
    "num_file_creations",
    "num_failed_logins",
    "num_root"
  ]
}
